<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ponderosa Site — Build Artifacts</title>
    <style>
      :root { color-scheme: dark; }
      body { margin: 0; font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial; background: #1a0e2e; color: #f0ebe0; }
      header { padding: 16px 18px; border-bottom: 1px solid rgba(201,168,76,.18); position: sticky; top: 0; background: rgba(26,14,46,.92); backdrop-filter: blur(8px); }
      h1 { margin: 0; font-size: 14px; font-weight: 650; }
      main { max-width: 1100px; margin: 0 auto; padding: 18px; }

      .stack { display: flex; flex-direction: column; gap: 18px; }
      .row { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
      @media (max-width: 920px) {
        .row { grid-template-columns: 1fr; }
      }

      .card { border: 1px solid rgba(201,168,76,.18); border-radius: 12px; padding: 12px; background: rgba(255,255,255,.03); }
      .card h2 { margin: 0 0 10px; font-size: 12px; letter-spacing: .2px; opacity: .9; }
      img { width: 100%; height: auto; border-radius: 10px; border: 1px solid rgba(201,168,76,.10); background: rgba(0,0,0,.18); }
      a { color: #e8c34a; text-decoration: none; }
      a:hover { text-decoration: underline; }
      footer { padding: 18px; font-size: 12px; opacity: .75; text-align: center; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
    </style>
  </head>
  <body>
    <header>
      <h1>Ponderosa Site — Screenshots</h1>
    </header>
    <main>
      <div class="stack">
        <div class="row">
          <section class="card">
            <h2>desktop — home</h2>
            <a href="screenshots/desktop-home.png"><img src="screenshots/desktop-home.png" alt="desktop home" /></a>
          </section>
          <section class="card">
            <h2>desktop — about</h2>
            <a href="screenshots/desktop-about.png"><img src="screenshots/desktop-about.png" alt="desktop about" /></a>
          </section>
        </div>

        <div class="row">
          <section class="card">
            <h2>mobile — home</h2>
            <a href="screenshots/mobile-home.png"><img src="screenshots/mobile-home.png" alt="mobile home" /></a>
          </section>
          <section class="card">
            <h2>mobile — about</h2>
            <a href="screenshots/mobile-about.png"><img src="screenshots/mobile-about.png" alt="mobile about" /></a>
          </section>
        </div>
      </div>
    </main>
    <footer>
      Generated by <code>scripts/ci/generate-build-artifacts.sh</code>
      — <a href="dev-server.log">dev-server.log</a>
    </footer>
  </body>
</html>
